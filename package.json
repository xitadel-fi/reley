{
  "name": "reley",
  "version": "1.0.0-beta.1",
  "private": true,
  "description": "Solana program cloner + LiteSVM sandbox with simulation, replay, trace, and diff",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm --filter @reley/shared build && pnpm --filter @reley/core build && pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist out .tsbuildinfo tsconfig.tsbuildinfo",
    "cli": "pnpm --filter @reley/core-cli start",
    "release": "node scripts/release.mjs",
    "publish:all": "scripts/publish.sh",
    "publish:dry": "scripts/publish.sh --dry-run",
    "publish:beta": "scripts/publish.sh --tag beta"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
