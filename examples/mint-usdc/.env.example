# Copy to .env and fill in.

# Full session URL from Reley → Inspector → Details → RPC endpoint → Copy session URL
RELEY_SESSION_URL=http://127.0.0.1:8899/session/REPLACE-WITH-SESSION-ID

# Keypair secret. Accepts either:
#   1. base58-encoded 64-byte secret key (Phantom / Solflare export format)
#   2. path to a Solana-CLI JSON keypair file (array of 64 numbers)
#   3. inline JSON array literal e.g. [12,34,...]
PAYER_KEYPAIR=PASTE_BASE58_SECRET_OR_./payer.json
MINT_AUTHORITY_KEYPAIR=PASTE_BASE58_SECRET_OR_./mint-authority.json

# base58 pubkey that will receive USDC
RECIPIENT_PUBKEY=REPLACE-WITH-RECIPIENT-PUBKEY

# Whole USDC amount to mint (will be multiplied by 10^6)
AMOUNT_USDC=1000

# Optional — overrides the mint address. Defaults to mainnet USDC.
# USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
