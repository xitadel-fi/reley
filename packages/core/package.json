{
  "name": "@reley/core",
  "version": "1.0.0-beta.1",
  "description": "Reley engine — LiteSVM sandbox, RPC cloner, Anchor patcher, replayer, trace parser, and snapshot store.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/relay-protocol/reley.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/relay-protocol/reley#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./svm": {
      "types": "./dist/svm/index.d.ts",
      "import": "./dist/svm/index.js"
    },
    "./cloner": {
      "types": "./dist/cloner/index.d.ts",
      "import": "./dist/cloner/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@reley/shared": "workspace:*",
    "@solana/web3.js": "^1.95.0",
    "litesvm": "^0.2.0",
    "bs58": "^6.0.0",
    "bn.js": "^5.2.1",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
