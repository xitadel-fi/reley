{
  "name": "@reley/core-cli",
  "version": "1.0.0-beta.2",
  "description": "Reley CLI — clone Solana programs, run them in LiteSVM, replay mainnet txs, build + sign + simulate tx templates.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "reley": "./dist/cli.js",
    "relay": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/relay-protocol/reley.git",
    "directory": "packages/core-cli"
  },
  "homepage": "https://github.com/relay-protocol/reley#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/cli.ts",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@reley/core": "workspace:*",
    "@reley/shared": "workspace:*",
    "@solana/web3.js": "^1.95.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
